components {
  parser "rust" {
    process {
      command "./target/release/tgraphy-parser-rust"
      args
    }
  }
  evaluator "rust-static" {
    process {
      command "./target/release/tgraphy-evaluator-rust-static"
      args
    }
  }
  reporter "json" {
    process {
      command "./target/release/tgraphy-reporter-json"
      args
    }
  }
  reporter "markdown" {
    process {
      command "./target/release/tgraphy-reporter-markdown"
      args
    }
  }
}